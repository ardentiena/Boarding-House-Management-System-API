# Environment variables for Boarding House API
# DO NOT COMMIT THIS FILE TO VERSION CONTROL. This file should be used for local development only. For production, set these environment variables in your deployment environment (e.g., Docker, Kubernetes, cloud provider).

# Database configuration
DB_HOST=localhost
DB_PORT=5432
# Replace these with your actual database name and username.
DB_NAME=your_database_name_here
DB_USER=your_database_username_here
# Replace this with your actual database password.
DB_PASSWORD=your_database_password_here

# JWT configuration
JWT_SECRET=generate_your_own_secret_key_here_do_not_use_this_in_production

# Midtrans configuration (sandbox keys for testing)
# Replace these with your actual Midtrans server and client keys for production
MIDTRANS_SERVER_KEY=Mid-server-your_server_key_here
MIDTRANS_CLIENT_KEY=Mid-client-your_client_key_here

# CORS configuration
# Specify allowed origins for CORS. This should be a comma-separated list of allowed origins (e.g., http://localhost:3000,http://localhost:5173). For production, set this to the actual domains that will access the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# Admin auth configuration
# Admin username and password for seeding initial admin user. In production, set these to secure values.
ADMIN_USERNAME=your_admin_username_here
ADMIN_PASSWORD=your_admin_password_here